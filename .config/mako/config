# Mako — Nord theme — Émile Turcotte
# https://man.archlinux.org/man/mako.5

font=JetBrainsMono Nerd Font 11
background-color=#2e3440
text-color=#d8dee9
border-color=#88c0d0
progress-color=over #434c5e

width=360
height=120
margin=12
padding=12
border-size=2
border-radius=10
icons=1
max-icon-size=48
default-timeout=5000
ignore-timeout=0
anchor=top-right
layer=overlay
max-visible=5

[urgency=low]
border-color=#4c566a
default-timeout=3000

[urgency=normal]
border-color=#88c0d0

[urgency=critical]
border-color=#bf616a
text-color=#eceff4
default-timeout=0
